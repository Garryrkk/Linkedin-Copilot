# Copy to .env and fill in. Nothing here is a real secret.

# App
DEBUG=true
SECRET_KEY=change-me-in-production

# Database (Postgres, asyncpg driver swapped in automatically by db/session.py)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/engageiq

# Required — every agent call (intake cleanup, context analysis, strategy
# selection, comment generation, voice rewrite, quality scoring) goes
# through core/llm.py using this key.
LLM_API_KEY=
LLM_MODEL=gpt-4o

# Optional — point core/llm.py at a local OpenAI-compatible server (e.g.
# llama.cpp's llama-server.exe, koboldcpp, LM Studio) instead of OpenAI.
# Leave blank to use the real OpenAI API.
LLM_BASE_URL=

# Optional — only used for screenshot OCR (agent1_intake.py). Falls back to
# local Tesseract if unset.
MISTRAL_API_KEY=

# Frontend origin(s) allowed to call this API
CORS_ORIGINS=["http://localhost:3000"]

# Minimum total_score (out of 50: 5 dimensions x 0-10) for a comment to
# pass the quality filter in agent6_quality.py
QUALITY_MIN_SCORE=40
